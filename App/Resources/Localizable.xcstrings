    "Press Start to capture. If nothing shows up, reinstall the helper below.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按开始抓包。若没有内容,请点下方重装 helper。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按開始抓包。若沒有內容,請點下方重新安裝 helper。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "開始を押してキャプチャします。何も表示されない場合は、下のボタンでヘルパーを再インストールしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시작을 눌러 캡처하세요. 아무것도 나타나지 않으면 아래에서 도우미를 다시 설치하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez sur Démarrer pour capturer. Si rien n'apparaît, réinstallez l'assistant ci-dessous."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Drücken Sie Start. Erscheint nichts, installieren Sie den Helfer unten neu."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pulsa Iniciar para capturar. Si no aparece nada, reinstala el asistente abajo."
          }
        }
      }
    },
