    "Connections you make while monitoring is on are recorded here.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "监控开启期间产生的连接会记录在这里。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "監控開啟期間產生的連線會記錄在這裡。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "監視がオンの間に行った接続はここに記録されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모니터링이 켜져 있는 동안 만든 연결이 여기에 기록됩니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les connexions établies pendant la surveillance sont enregistrées ici."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbindungen, die Sie bei aktiver Überwachung herstellen, werden hier aufgezeichnet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las conexiones que realices con la supervisión activada se registran aquí."
          }
        }
      }
    },
