    "Network quality is measured for TCP connections.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Netzwerkqualität wird für TCP-Verbindungen gemessen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La calidad de red se mide para conexiones TCP."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La qualité du réseau est mesurée pour les connexions TCP."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ネットワーク品質は TCP 接続で測定されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "네트워크 품질은 TCP 연결에서 측정됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "网络质量针对 TCP 连接进行测量。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "網路品質針對 TCP 連線進行測量。"
          }
        }
      }
    },
    "Handshake not captured (connection opened before capture).": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Handshake nicht erfasst (Verbindung vor der Erfassung geöffnet)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Handshake no capturado (la conexión se abrió antes de la captura)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Handshake non capturé (connexion ouverte avant la capture)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ハンドシェイクは記録されていません(キャプチャ開始前に接続が確立)。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "핸드셰이크가 캡처되지 않음(캡처 전에 연결이 열림)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未捕获握手(连接在抓包前已建立)。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未擷取交握(連線在抓包前已建立)。"
          }
        }
      }
    },
    "No quality data observed yet for this connection.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch keine Qualitätsdaten für diese Verbindung beobachtet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no se han observado datos de calidad para esta conexión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune donnée de qualité observée pour cette connexion."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この接続の品質データはまだありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 연결에 대한 품질 데이터가 아직 없습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "尚未观测到此连接的质量数据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "尚未觀測到此連線的品質資料。"
          }
        }
      }
    },
    "Enable packet capture in the Packets tab to measure network quality.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivieren Sie die Paketerfassung im Tab „Pakete“, um die Netzwerkqualität zu messen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Active la captura de paquetes en la pestaña Paquetes para medir la calidad de red."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez la capture de paquets dans l’onglet Paquets pour mesurer la qualité du réseau."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ネットワーク品質を測定するには、「パケット」タブでパケットキャプチャを有効にしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "네트워크 품질을 측정하려면 패킷 탭에서 패킷 캡처를 활성화하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在“数据包”标签页启用抓包以测量网络质量。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在「封包」標籤頁啟用抓包以測量網路品質。"
          }
        }
      }
    }
