    "Select a connection to inspect its endpoints and traffic.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择一条连接以查看其端点与流量。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇一條連線以檢視其端點與流量。"
