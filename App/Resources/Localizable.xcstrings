    "Keep monitoring from the menu bar with no Dock icon, so the widget stays fresh.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "隐藏 Dock 图标,从菜单栏持续监控,让小组件保持最新。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "隱藏 Dock 圖示,從選單列持續監控,讓小工具保持最新。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Dock アイコンを表示せずメニューバーから監視を続け、ウィジェットを最新に保ちます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Dock 아이콘 없이 메뉴 막대에서 모니터링을 계속하여 위젯을 최신으로 유지합니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Continuer la surveillance depuis la barre des menus, sans icône du Dock, pour garder le widget à jour."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ohne Dock-Symbol über die Menüleiste überwachen, damit das Widget aktuell bleibt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Supervisa desde la barra de menús sin icono en el Dock, para mantener el widget actualizado."
          }
        }
      }
    },
    "Datasets refresh automatically; MatrixNet only contacts its own release assets.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "数据集自动在后台刷新;MatrixNet 仅访问自己的发布资源。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "資料集自動在背景重新整理;MatrixNet 僅存取自己的發行資源。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "データセットは自動的に更新されます。MatrixNet は自身のリリースアセットにのみアクセスします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "데이터셋은 자동으로 갱신됩니다. MatrixNet은 자체 릴리스 자산에만 연결합니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les jeux de données se mettent à jour automatiquement ; MatrixNet ne contacte que ses propres ressources de version."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Datensätze werden automatisch aktualisiert; MatrixNet kontaktiert nur seine eigenen Release-Ressourcen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los conjuntos de datos se actualizan automáticamente; MatrixNet solo contacta con sus propios recursos de versión."
          }
        }
      }
    },
