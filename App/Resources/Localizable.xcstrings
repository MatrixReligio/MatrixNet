    "Start monitoring to see which apps are talking to the network — no special permissions required.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开始监控即可查看哪些 App 正在与网络通信 —— 无需任何特殊权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開始監控即可檢視哪些 App 正在與網路通訊 —— 無需任何特殊權限。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "監視を開始すると、どの App がネットワークと通信しているかを確認できます。特別な権限は不要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모니터링을 시작하면 어떤 App이 네트워크와 통신하는지 확인할 수 있습니다. 특별한 권한이 필요하지 않습니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Démarrez la surveillance pour voir quelles apps communiquent avec le réseau — aucune autorisation spéciale requise."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Starten Sie die Überwachung, um zu sehen, welche Apps mit dem Netzwerk kommunizieren – keine besonderen Berechtigungen erforderlich."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicia la supervisión para ver qué apps se comunican con la red: no se requieren permisos especiales."
          }
        }
      }
    },
