    "Listening for connections. Activity from every app will appear here.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在监听连接,所有 App 的网络活动都会显示在这里。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "正在監聽連線,所有 App 的網路活動都會顯示在這裡。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続を待機しています。すべての App のアクティビティがここに表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "연결을 수신하고 있습니다. 모든 App의 활동이 여기에 표시됩니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À l’écoute des connexions. L’activité de chaque app apparaîtra ici."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Warten auf Verbindungen. Aktivität jeder App erscheint hier."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escuchando conexiones. La actividad de cada app aparecerá aquí."
          }
        }
      }
    },
    "Live network activity, throughput, and the apps using your connection.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "实时网络活动、吞吐量,以及正在使用你网络的 App。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "即時網路活動、吞吐量,以及正在使用你網路的 App。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リアルタイムのネットワーク活動、スループット、接続を使用している App。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "실시간 네트워크 활동, 처리량 및 연결을 사용하는 App."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activité réseau en direct, débit et apps utilisant votre connexion."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Live-Netzwerkaktivität, Durchsatz und die Apps, die Ihre Verbindung nutzen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Actividad de red en vivo, rendimiento y las apps que usan tu conexión."
          }
        }
      }
    },
