    "Approve “MatrixNet” in System Settings → General → Login Items & Extensions, then press Start.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 系统设置 → 通用 → 登录项与扩展 中批准“MatrixNet”,然后按开始。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在 系統設定 → 一般 → 登入項目與延伸功能 中批准“MatrixNet”,然後按開始。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システム設定 → 一般 → ログイン項目と機能拡張 で「MatrixNet」を承認してから、開始を押してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템 설정 → 일반 → 로그인 항목 및 확장 프로그램에서 “MatrixNet”을 승인한 다음 시작을 누르세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Approuvez « MatrixNet » dans Réglages Système → Général → Ouverture et extensions, puis appuyez sur Démarrer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Genehmigen Sie „MatrixNet“ in Systemeinstellungen → Allgemein → Anmeldeobjekte & Erweiterungen und drücken Sie dann Start."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aprueba «MatrixNet» en Ajustes del Sistema → General → Ítems de inicio y extensiones y luego pulsa Iniciar."
          }
        }
      }
    },
