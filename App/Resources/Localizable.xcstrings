    "Start MatrixNet at login — added silently; verify under Login Items.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "登录时自动启动 MatrixNet —— 静默添加;可在“登录项”中核验。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "登入時自動啟動 MatrixNet —— 靜默加入;可在「登入項目」中核驗。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ログイン時に MatrixNet を起動 —— サイレントに追加。「ログイン項目」で確認できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로그인 시 MatrixNet 시작 —— 자동 추가되며 ‘로그인 항목’에서 확인 가능."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lancer MatrixNet à la connexion — ajouté en silence ; vérifiez dans « Ouverture »."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "MatrixNet beim Anmelden starten — ohne Hinweis hinzugefügt; prüfen unter „Anmeldeobjekte“."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Iniciar MatrixNet al iniciar sesión — añadido en silencio; verifícalo en «Elementos de inicio»."
          }
        }
      }
    },
