    "Where the Map’s “this Mac” anchor sits. Defaults to your system region.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "地图上“本机”锚点的位置。默认跟随系统地区。"
