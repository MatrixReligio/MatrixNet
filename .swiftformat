# SwiftFormat configuration for MatrixNet
# Docs: https://github.com/nicklockwood/SwiftFormat

--swiftversion 6.0

# Rules
--enable isEmpty
--enable blankLinesBetweenScopes
--enable wrapMultilineStatementBraces
--enable redundantReturn
--enable redundantSelf
--enable trailingCommas
--enable sortedImports

--disable wrapMultilineConditionalAssignment

# Options
--indent 4
--maxwidth 120
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--commas inline
--semicolons never
--trimwhitespace always
--self remove
--importgrouping testable-bottom
--header strip

# Exclusions
--exclude .build,DerivedData,build,Package.swift
